{
  "name": "household-ledger-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "typescript": "5.8.2"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "ops:harness:web": "node --env-file=.env scripts/ops/web-recurring-harness.mjs",
    "ops:deploy-recurring-function": "node --env-file=.env scripts/ops/deploy-recurring-function.mjs",
    "ops:check-env": "node --env-file=.env scripts/ops/validate-runtime-env.mjs",
    "ops:check-harness-runner": "node --env-file=.env scripts/ops/check-harness-runner.mjs",
    "ops:pr-rehearsal": "node --env-file=.env scripts/ops/pr-rehearsal.mjs",
    "ops:check-recurring-batch": "node --env-file=.env scripts/ops/check-recurring-batch.mjs",
    "ops:check-recurring-batch:execute": "node --env-file=.env scripts/ops/check-recurring-batch.mjs --execute",
    "ops:preflight": "node --env-file=.env scripts/ops/preflight.mjs",
    "ops:preflight:local": "node --env-file=.env scripts/ops/preflight.mjs --skip-batch --allow-missing",
    "ops:github:protect-main": "node --env-file=.env scripts/ops/apply-branch-protection.mjs --apply",
    "ops:github:protect-main:dry": "node --env-file=.env scripts/ops/apply-branch-protection.mjs",
    "ops:progress": "node --env-file=.env scripts/ops/progress-report.mjs",
    "ops:ready": "node --env-file=.env scripts/ops/ready-check.mjs",
    "ops:ready:full": "node --env-file=.env scripts/ops/ready-check.mjs --with-env --with-batch",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/ops/smoke.ps1",
    "smoke:with-env": "powershell -ExecutionPolicy Bypass -File scripts/ops/smoke.ps1 -WithEnv",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
