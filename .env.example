# Shared Supabase settings
# Public keys only. Never expose the service role key to web or mobile clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only settings
# Use only for protected server jobs, admin scripts, or scheduled batch jobs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# App defaults
NEXT_PUBLIC_DEFAULT_CURRENCY=KRW
EXPO_PUBLIC_DEFAULT_CURRENCY=KRW

# Agent runner LLM provider settings
# AGENT_PROVIDER:
# - openai_responses (default)
# - openai_compatible_chat (Ollama/vLLM/TGI style endpoints)
# - gemini_generate_content
AGENT_PROVIDER=openai_responses
AGENT_MODEL=gpt-5.3-codex

# For OpenAI or OpenAI-compatible providers
OPENAI_API_KEY=
AGENT_API_KEY=
AGENT_API_BASE=

# For Gemini provider
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_BASE=

# Harness check options
PYTHON_BIN=C:\Python314\python.exe
HARNESS_ALLOW_FALLBACK=0
