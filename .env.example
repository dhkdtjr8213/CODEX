# Shared Supabase settings
# Public keys only. Never expose the service role key to web or mobile clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only settings
# Use only for protected server jobs, admin scripts, or scheduled batch jobs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# App defaults
NEXT_PUBLIC_DEFAULT_CURRENCY=KRW
EXPO_PUBLIC_DEFAULT_CURRENCY=KRW
